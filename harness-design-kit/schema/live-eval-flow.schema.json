{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness Design Kit Live Eval Flow",
  "type": "object",
  "required": [
    "steps"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "command_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "cwd": {
            "type": "string"
          },
          "expect_exit_code": {
            "type": "integer"
          },
          "expect_contains": {
            "type": "string"
          },
          "expect_regex": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "goto",
              "click",
              "fill",
              "press",
              "assert_text",
              "assert_url",
              "assert_request",
              "assert_response",
              "assert_storage",
              "screenshot",
              "wait"
            ]
          },
          "name": {
            "type": "string"
          },
          "selector": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "url_contains": {
            "type": "string"
          },
          "method": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "storage": {
            "type": "string",
            "enum": [
              "local",
              "session"
            ]
          },
          "equals": {
            "type": "string"
          },
          "includes": {
            "type": "string"
          },
          "non_empty": {
            "type": "boolean"
          },
          "timeout_ms": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
